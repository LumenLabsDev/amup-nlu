{
  "name": "root",
  "private": true,
  "description": "Library for NLU (Natural Language Understanding) done in Node.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "coveralls": "jest --coverage && cat ./tests/coverage/lcov.info | coveralls",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx}\" && node scripts/format-json.js --all",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,ts,tsx}\" && node scripts/format-json.js --check",
    "lint": "eslint .",
    "lintfix": "eslint --fix .",
    "prepare": "husky",
    "test": "npm run lint && npm run test:jest",
    "test:jest": "cross-env TZ=Europe/London jest --silent --coverage --maxWorkers=4 ."
  },
  "engines": {
    "node": ">=22 <23 || >=24 <25 || >=26 <27"
  },
  "author": "Lumen Labs Dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LumenLabsDev/amup-nlu.git"
  },
  "bugs": {
    "url": "https://github.com/LumenLabsDev/amup-nlu/issues"
  },
  "homepage": "https://github.com/LumenLabsDev/amup-nlu#readme",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "coveralls": "^3.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.6",
    "https-proxy-agent": "^7.0.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^15.5.2",
    "lerna": "^9.0.7",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/src/**/**.js",
      "!./packages/lang-**/**",
      "!./packages/python-compiler/src/python-executer.js"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "publisher": "Lumen Labs Dev"
}
