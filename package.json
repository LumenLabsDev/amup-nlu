{
  "name": "root",
  "private": true,
  "description": "Library for NLU (Natural Language Understanding) done in Node.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "coveralls": "jest --coverage && cat ./tests/coverage/lcov.info | coveralls",
    "lint": "eslint .",
    "lintfix": "eslint --fix .",
    "test": "npm run lint && npm run test:jest",
    "test:jest": "cross-env TZ=Europe/London jest --silent --coverage --maxWorkers=4 .",
    "test:jest:no-open-question": "cross-env TZ=Europe/London jest --silent --coverage --maxWorkers=4 . --testPathIgnorePatterns packages/open-question"
  },
  "engines": {
    "node": ">=22 <23 || >=24 <25 || >=26 <27"
  },
  "author": {
    "email": "opensource@axa.com",
    "name": "Jesus Seijas"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axa-group/nlp.js.git"
  },
  "bugs": {
    "url": "https://github.com/axa-group/nlp.js/issues"
  },
  "homepage": "https://github.com/axa-group/nlp.js#readme",
  "maintainers": [
    {
      "email": "opensource@axa.com",
      "name": "Jesus Seijas"
    }
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "coveralls": "^3.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.22.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^26.0.0",
    "eslint-plugin-prettier": "^4.0.0",
    "https-proxy-agent": "^5.0.0",
    "jest": "^29.3.1",
    "lerna": "^6.1.0",
    "prettier": "^2.2.1",
    "supertest": "^6.1.3"
  },
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/src/**/**.js",
      "!./packages/lang-**/**",
      "!./packages/python-compiler/src/python-executer.js",
      "!./packages/express-api-server/src/public/**/**"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
